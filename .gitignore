# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Env files (allow templates)
.env
.env.*
!.env.example
!.env.*.example

# Frontend dependencies and build artifacts
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/coverage/

# TypeScript incremental/build outputs
frontend/*.tsbuildinfo
frontend/**/*.tsbuildinfo
frontend/**/*.d.ts.map

# Accidental JS/typing emission from tooling configs
frontend/vite.config.js
frontend/vite.config.d.ts

# Generic temporary files
*.tmp
*.temp
