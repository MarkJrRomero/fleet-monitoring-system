# Contrato global de variables de entorno para fleet-monitoring-system
# Copia este archivo a .env y ajustalo para tu maquina/gestor de secretos.

# -----------------------------------------------------------------------------
# Configuracion global del proyecto
# -----------------------------------------------------------------------------
APP_ENV=dev
COMPOSE_PROJECT_NAME=fleet-monitoring

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
FRONTEND_PORT=5173
FRONTEND_URL=http://localhost:5173
FRONTEND_API_BASE_URL=http://localhost:8081
FRONTEND_AUTH_URL=http://localhost:8080
FRONTEND_AUTH_REALM=fleet-monitoring
FRONTEND_AUTH_CLIENT_ID=fleet-web-client

# -----------------------------------------------------------------------------
# Keycloak
# -----------------------------------------------------------------------------
KEYCLOAK_PORT=8080
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_REALM=fleet-monitoring
KEYCLOAK_IMPORT_FILE=../.docker/keycloak/realm-export.json

# -----------------------------------------------------------------------------
# ClickHouse (analitica historica)
# -----------------------------------------------------------------------------
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
CLICKHOUSE_ENABLED=true
CLICKHOUSE_ADDR=clickhouse:9000
CLICKHOUSE_DATABASE=default
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=clickhouse
CLICKHOUSE_BATCH_SIZE=100
CLICKHOUSE_FLUSH_INTERVAL_SECONDS=3

# -----------------------------------------------------------------------------
# Microservicios (placeholders para los siguientes pasos)
# -----------------------------------------------------------------------------
API_PORT=8081
API_BASE_URL=http://localhost:8081
API_JWT_ISSUER=http://localhost:8080/realms/fleet-monitoring
API_JWT_AUDIENCE=account
INGESTION_SERVICE_PORT=8091
INGESTION_RECENT_TTL_SECONDS=60
INGESTION_DEDUPE_WINDOW_SECONDS=15
NOMINATIM_REVERSE_URL=https://nominatim.openstreetmap.org/reverse
NOMINATIM_USER_AGENT=fleet-monitoring-system/1.0 (dev)
ALERTS_CHANNEL=alerts:stream
ROUTING_SERVICE_URL=http://routing-service:8095
INGESTION_RETRY_QUEUE_SIZE=1000
INGESTION_CB_FAILURE_THRESHOLD=3
INGESTION_CB_RESET_SECONDS=30
WEBSOCKET_SERVICE_PORT=8093
VEHICLE_SERVICE_PORT=8094
INGESTION_BASE_URL=http://ingestion-service:8091
REDIS_POSITIONS_CHANNEL=gps:stream
REDIS_ALERTS_CHANNEL=alerts:stream
NOTIFICATION_SERVICE_PORT=8092

# Infraestructura compartida para microservicios
REDIS_PORT=6379
REDIS_URL=redis://redis:6379
REDIS_UI_PORT=8089
REDIS_UI_USER=admin
REDIS_UI_PASSWORD=admin

POSTGRES_PORT=5432
POSTGRES_DB=fleet_monitoring
POSTGRES_USER=fleet_user
POSTGRES_PASSWORD=fleet_password
POSTGRES_HOST=postgres
POSTGRES_SSLMODE=disable
DB_ADMIN_PORT=8088
